generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Conexión directa (sin pooler) para migraciones, recomendado por Neon.
  directUrl = env("DIRECT_DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Usuarios internos (Admin / Trabajador)
// ---------------------------------------------------------------------------
model User {
  id       String @id @default(cuid())
  name     String
  email    String @unique
  password String // hash bcrypt, nunca texto plano

  role String @default("trabajador") // "admin" | "trabajador"

  // Endurecimiento contra fuerza bruta en login
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  proyectosCreados Project[]      @relation("ProyectosCreadosPor")
  fasesResponsable Phase[]        @relation("FaseResponsable")
  historialCambios StatusHistory[] @relation("HistorialCambiadoPor")
  auditLogs        AuditLog[]

  @@map("users")
}

// ---------------------------------------------------------------------------
// Proyecto / Pedido del cliente
// ---------------------------------------------------------------------------
model Project {
  id    String @id @default(cuid())
  folio String @unique

  // "borrador"  -> guardado para seguir editando, aún no notifica al cliente
  // "registrado" -> alta definitiva, ya se generó folio+PDF+correo
  recordStatus String @default("borrador")

  // Estatus general de avance (independiente de recordStatus):
  // "en_proceso" | "entregado". Se marca "entregado" automáticamente cuando
  // se completa el punto principal "entregado" (ver Fase 4).
  status      String    @default("en_proceso")
  deliveredAt DateTime?

  // Breve descripción del trabajo (para identificarlo en listados,
  // ej. "Molde para tapa de envase 500ml")
  title String

  // Datos del cliente
  clientName String
  company    String?
  phone      String
  email      String?

  // Datos financieros
  cost           Float?
  advancePayment Float? @default(0)
  paymentStatus  String @default("pendiente") // "pendiente" | "anticipo" | "pagado"

  notes String?

  // Firmas (dataURL / imagen subida)
  clientSignature   String?
  receiverSignature String?

  // Fechas de entrega
  estimatedDeliveryAuto   DateTime? // sugerida por el sistema (suma de días hábiles)
  estimatedDeliveryManual DateTime? // ajustada a mano por el Admin (si existe, esta manda)

  // Visibilidad para el cliente: ¿puede ver el primer nivel de subpuntos (1.1, 1.2...)?
  clientCanSeeSubpoints Boolean @default(false)

  createdById String
  createdBy   User   @relation("ProyectosCreadosPor", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  phases        Phase[]
  statusHistory StatusHistory[]

  @@map("projects")
}

// ---------------------------------------------------------------------------
// Fase / Punto (árbol autorreferencial de profundidad infinita)
// depth 0  = Punto Principal, siempre visible al cliente. La cantidad y
//            nombres de estos puntos ya NO son fijos: se copian del catálogo
//            configurable (MainPointTemplate) al momento de crear el
//            proyecto, y desde ahí quedan totalmente independientes de ese
//            catálogo (ver comentario de MainPointTemplate más abajo). Los
//            últimos 2 siempre son "listo_entrega" y "entregado", en ese
//            orden — esos sí siguen siendo fijos en todo el sistema.
// depth 1  = Subpunto (visible al cliente solo si Project.clientCanSeeSubpoints)
// depth 2+ = Sub-subpunto (nunca visible al cliente, solo uso interno)
// ---------------------------------------------------------------------------
model Phase {
  id        String @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  parentId String?
  parent   Phase?  @relation("PhaseTree", fields: [parentId], references: [id], onDelete: Cascade)
  children Phase[] @relation("PhaseTree")

  depth Int // 0, 1, 2, 3...
  order Int @default(0) // orden entre hermanos

  // Solo se usa en los puntos principales (depth 0). Identifica de qué punto
  // del catálogo salió este punto al crear el proyecto (o "listo_entrega" /
  // "entregado" para los 2 fijos). Es un snapshot: aunque el catálogo cambie
  // después, este valor y el resto de la fase no se ven afectados.
  mainPointKey String?

  title       String // título corto
  description String? // descripción larga (uso interno)

  responsibleId String
  responsible   User   @relation("FaseResponsable", fields: [responsibleId], references: [id])

  status String @default("pendiente") // "pendiente" | "en_proceso" | "completado"

  estimatedDays Int? // solo relevante en depth 0, para calcular la fecha de entrega
  startDate     DateTime?
  endDate       DateTime?
  completedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([parentId])
  @@index([responsibleId])
  @@map("phases")
}

// ---------------------------------------------------------------------------
// Catálogo de Puntos Principales (configurable por el Admin desde
// Configuración). Es solo una PLANTILLA que se copia al crear un proyecto
// NUEVO: una vez creado, cada proyecto guarda sus propias Phase (depth 0) de
// forma independiente. Editar este catálogo después (agregar, renombrar,
// reordenar o desactivar un punto) NUNCA modifica proyectos ya existentes,
// ni registrados ni borradores — si un borrador necesita reflejar un cambio
// de catálogo, se cancela/elimina y se vuelve a crear (ya existe esa
// capacidad de gestión de borradores).
//
// "listo_entrega" y "entregado" son las 2 filas fijas/protegidas: siempre
// existen, siempre van al final (order muy alto), nunca se pueden borrar,
// renombrar ni reordenar desde la UI — conservan la key literal que ya usa
// el resto del código (esPuntoSoloEstatus, reglas de secuencia en
// /api/fases/[id]).
// ---------------------------------------------------------------------------
model MainPointTemplate {
  id String @id @default(cuid())

  // Para los 2 puntos fijos: literalmente "listo_entrega" / "entregado".
  // Para puntos configurables: un identificador opaco único, sin
  // significado semántico, solo para identificar la fila.
  key String @unique

  label String
  order Int

  // Puntos fijos protegidos (Listo para Entrega / Entregado): no se pueden
  // editar, reordenar ni desactivar desde la UI de Configuración.
  fixed Boolean @default(false)

  // Desactivado = ya no se ofrece para proyectos nuevos, pero se conserva el
  // registro (nunca se borra de verdad). No afecta proyectos existentes, que
  // ya tienen su propia copia guardada en sus Phase.
  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("main_point_templates")
}

// ---------------------------------------------------------------------------
// Historial de estatus (auditoría visible en seguimiento + interno)
// ---------------------------------------------------------------------------
model StatusHistory {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  phaseId String? // null = evento a nivel proyecto (ej. cambio de fecha de entrega)

  status String
  note   String?

  changedById String?
  changedBy   User?   @relation("HistorialCambiadoPor", fields: [changedById], references: [id])

  createdAt DateTime @default(now())

  @@index([projectId])
  @@map("status_history")
}

// ---------------------------------------------------------------------------
// Bitácora de seguridad (acciones sensibles: logins, altas de usuario, etc.)
// ---------------------------------------------------------------------------
model AuditLog {
  id     String  @id @default(cuid())
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  action     String // ej. "login_success", "login_failed", "user_created", "password_changed"
  targetType String? // ej. "Project", "User", "Phase"
  targetId   String?
  metadata   Json?
  ipAddress  String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@map("audit_logs")
}
