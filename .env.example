# Copia este archivo a .env.local y llena los valores reales.
# .env.local NUNCA se sube a git (ya está en .gitignore).

# --- Base de datos (Neon) ---
# Ve a https://console.neon.tech -> tu proyecto -> Connection string
# DATABASE_URL = la conexión "Pooled" (para la app en runtime)
# DIRECT_DATABASE_URL = la conexión "Direct"/sin pooler (Prisma la necesita para migraciones)
DATABASE_URL="postgresql://usuario:password@host-pooler.neon.tech/brosma?sslmode=require"
DIRECT_DATABASE_URL="postgresql://usuario:password@host.neon.tech/brosma?sslmode=require"

# --- NextAuth ---
# Genera un valor random con: openssl rand -base64 32
AUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# --- Cloudinary (fotos/adjuntos) ---
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# --- Resend (correo) ---
RESEND_API_KEY=""
RESEND_FROM="Brosma <onboarding@resend.dev>"

# --- Upstash Redis (rate limiting anti fuerza-bruta) ---
# Se usa en Fase 5. Se puede dejar vacío por ahora.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
